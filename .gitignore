# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment ───────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Raw input data (large satellite files – download separately) ──────────────
data/raw/
# Large processed rasters (100MB+ – regenerated by pipeline)
data/processed/*.tif

# ── Keep pipeline outputs (GeoJSON, JSON reports) ─────────────────────────────
!data/exports/
!data/exports/*.geojson
!data/exports/*.json

# ── Dashboard overlay PNGs (>5 MB each, regenerated by generate_map_overlays.py)
dashboard/data/overlays/*.png

# ── Keep small static assets
!dashboard/static/ohrc_bounds.json

# ── OS cruft ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Scratch / temp ────────────────────────────────────────────────────────────
scratch/
apply_appjs_fixes.py
walkthrough.md
